//删除 BT 禁用配置
//一、删除个别 BT 禁用
//在 inbounds 中找到对应应用删除如下配置（单项配置）
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }


//二、删除全部 BT 禁用
//1、在 inbounds 中找到每个应用一一删除如下配置（单项配置）
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }

//2、在 routing 中删除如下配置（全局配置）
      {
        "type": "field",
        "protocol": [
          "bittorrent"
        ],
        "outboundTag": "block"
      }

//3、在 outbounds 中删除如下配置（全局配置）
    {
      "tag": "block",
      "protocol": "blackhole",
      "settings": {}
    }
